{
  "name": "dotfiles-web",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Showcase site for the dotfiles ecosystem (Core -> OS-native -> Role).",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "metrics": "node scripts/collect-metrics.mjs",
    "snippets": "node scripts/collect-snippets.mjs",
    "data": "npm run metrics && npm run snippets",
    "data:strict": "node scripts/collect-metrics.mjs --strict && npm run snippets",
    "verify:flags": "node scripts/verify-bootstrap-flags.mjs",
    "check": "astro check",
    "astro": "astro"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^22.20.0",
    "astro": "^6.4.6",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.10.0",
    "@xterm/xterm": "5.5.0"
  }
}
