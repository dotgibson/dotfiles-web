---
import Base from '../layouts/Base.astro';
import CommandBlock from '../components/CommandBlock.astro';
import ArchitectureDiagram from '../components/ArchitectureDiagram.astro';
import { withBase } from '../lib/url';

const loadOrder = [
  ['tools', 'detection + single init point (zoxide/starship/atuin/mise) — loads first'],
  ['ui', 'terminal-UX primitives (_core_err/ok/hint/confirm/spin), gum-aware'],
  ['options', 'setopts + completion system (compinit, cached) + zstyles'],
  ['history', 'HISTFILE/SIZE + history setopts + secret-ignore'],
  ['aliases', 'modern-CLI aliases, each guarded by tools.zsh detection'],
  ['git', 'curated OMZ-style git aliases + git_main_branch helper'],
  ['functions', 'cross-OS shell functions (mkcd, extract, up, …)'],
  ['fzf', 'fzf env + zle widgets (Ctrl-F/R, Alt-Z) + fif/fbr'],
  ['bindings', 'vi-mode keybindings (zvm_after_init hook)'],
  ['plugins', 'lightweight plugin loader + pinned plugin list'],
  ['op', '1Password CLI helpers'],
  ['maint / update', 'daily-maintenance surface + the up updater nudge'],
  ['os', 'the OS-native layer (os/<platform>.zsh)'],
  ['offensive', 'Kali only — engagement scaffolding'],
  ['defense', 'Defense only — detection/hunt tooling'],
  ['local', 'machine-specific overrides (untracked) — always wins'],
];

const comparisons = [
  {
    title: 'vs git submodule',
    body: 'A submodule stores a pointer, so a fresh clone is empty until git submodule update --init — the classic "I cloned it and nothing works" footgun. Subtree vendors the actual files, so every machine repo is self-contained and clone-and-go. The cost subtree pays back: a vendored copy in each repo (kept honest by the sync script + a manifest audit).',
  },
  {
    title: 'vs chezmoi / yadm',
    body: 'One repo + per-OS templates is the most DRY answer, and the right move the day you want to collapse ten repos into one. This system keeps the ten-repo portfolio instead — each machine is a clean, public, self-contained artifact. Because Core is already plain and OS-agnostic, moving to chezmoi later is a content migration, not a rewrite.',
  },
  {
    title: 'vs GNU stow',
    body: 'stow is a perfect, zero-magic symlink farmer over a single repo — and genuinely simpler if you have one machine. What it has no opinion about is layering or per-OS divergence, so a multi-OS setup drifts into host branches and .stow-local-ignore gymnastics. This system bakes the Core / OS / Role split in and ships its own idempotent symlinker (with backups + a dry-run).',
  },
  {
    title: 'vs a bare $HOME git repo',
    body: 'The git --bare + alias trick is the leanest possible — no symlinks, files live in $HOME. Hard to beat solo. But it has no layer model, no per-OS story, noisy status against your whole home dir, and it is a real footgun on a shared or multi-user box. This trades that leanness for an explicit, auditable structure.',
  },
];

// Intellectual honesty: when this design is the WRONG one. A system that can't name
// its own constraints isn't trustworthy — so say plainly who should reach for something
// lighter.
const notForYou = [
  'You have one or two machines with no real OS spread — this is over-engineered for that; a bare $HOME repo or stow is far less ceremony.',
  'You want ONE repo, not ten — reach for chezmoi or yadm. (The migration is content, not a rewrite, because Core is already plain.)',
  'You can’t stomach any vendored duplication — the ten-repo + vendored-Core model deliberately trades a little duplication for clone-and-go self-containment and a public per-machine portfolio.',
];

// The macOS desktop layer — committed GUI tooling the OS-native layer owns, themed to match
// Core. Lives in dotfiles-MacBook (aerospace/, sketchybar/, karabiner/).
const macDesktop = [
  {
    icon: '◳',
    name: 'AeroSpace',
    tone: 'blue',
    body: 'i3-style tiling window manager — pure TOML, no SIP disable required, no daemon. alt drives focus/move/resize and workspaces, apps auto-place on a home workspace, and JankyBorders rings the focused tile.',
  },
  {
    icon: '▭',
    name: 'SketchyBar',
    tone: 'purple',
    body: 'A programmable menu bar themed to tokyonight-storm, matching starship + tmux. Live AeroSpace workspaces on the left; CPU, memory, disk, network, and a click-to-toggle keep-awake on the right — every glyph from the one Nerd Font, no extra deps.',
  },
  {
    icon: '⌨',
    name: 'Karabiner',
    tone: 'cyan',
    body: 'Caps→Ctrl/Esc, and a Tab-hyper layer that mirrors the WM verbs — hyper+hjkl to focus, hyper+1–5 for workspaces — so the whole tiling workflow stays on the home row.',
  },
];

// Deep-dive docs that live in the repos but were previously unlinked from the site.
const blob = (repo: string, path: string) => `https://github.com/Gerrrt/${repo}/blob/main/${path}`;
const deepDives = [
  {
    title: 'Porting matrix',
    repo: 'dotfiles-core',
    href: blob('dotfiles-core', 'PORTING-MATRIX.md'),
    body: 'The per-distro lookup that turns the Fedora template into Arch, openSUSE, Alpine, and Gentoo — package manager, clipboard backend, and quirks, side by side.',
  },
  {
    title: 'Offensive methodology',
    repo: 'dotfiles-Kali',
    href: blob('dotfiles-Kali', 'OFFENSIVE-METHODOLOGY.md'),
    body: 'How the Kali role layer maps to MITRE ATT&CK tactics — NetExec, BloodHound CE, Impacket, certipy-ad — and where loot lands under ~/engagements.',
  },
  {
    title: 'Security policy',
    repo: 'dotfiles-core',
    href: blob('dotfiles-core', 'SECURITY.md'),
    body: 'The supply-chain stance: SHA-pinned plugins, pinned CI actions and pre-commit hooks, and how to report an issue.',
  },
  {
    title: 'Windows architecture audit',
    repo: 'dotfiles-Windows',
    href: blob('dotfiles-Windows', 'docs/ARCHITECTURE-AUDIT.md'),
    body: 'The structural audit behind the PowerShell host: fragment loader, coverage gate, and how the host layer bridges into WSL.',
  },
  {
    title: 'macOS migration guide',
    repo: 'dotfiles-MacBook',
    href: blob('dotfiles-MacBook', 'MIGRATION.md'),
    body: 'Moving an existing Mac onto the ecosystem without trampling what is already there.',
  },
  {
    title: 'Arch stage-0 setup',
    repo: 'dotfiles-Arch',
    href: blob('dotfiles-Arch', 'SETUP.md'),
    body: 'Bare-metal groundwork for a minimal Arch box — user, sudo, git, and a UTF-8 locale — before bootstrap can run.',
  },
];
---

<Base
  title="Architecture"
  description="The three-layer model behind the dotfiles ecosystem: a vendored Core, thin OS-native layers, and operator role layers (offensive Kali, defensive Defense) — wired together by git subtree and a canonical zsh load order."
>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Architecture</span>
        <h1>One Core, vendored everywhere</h1>
        <p class="lead">
          The system is built on one decision repeated consistently: draw a hard boundary
          between what is identical on every machine and what changes with the OS or the
          operator. Get the boundary right and a single Core can serve ten machines with
          zero special-casing.
        </p>
        <p class="lead mt">
          Prefer to just read it? <a href={withBase('/config')}>Browse the actual config for
          each layer →</a> — real files, pulled straight from the source repos.
        </p>
      </div>

      <!-- the rule -->
      <blockquote class="rule">
        <p>If it changes when the <em>operating system</em> changes, it does <strong>not</strong> belong in Core.</p>
        <p>If it changes when <em>you as an operator</em> change, it does <strong>not</strong> belong in Core.</p>
        <p class="rule__punch">Everything left over is Core — and it lives in exactly one place.</p>
      </blockquote>

      <!-- layer table -->
      <h2 class="mt">The three layers</h2>
      <div class="layer-table">
        <div class="layer-table__row layer-table__row--head">
          <span>Layer</span><span>Lives in</span><span>Examples</span>
        </div>
        <div class="layer-table__row">
          <span class="tone-purple text-mono">Core</span>
          <span>this repo, vendored into each OS repo via <code>git subtree</code></span>
          <span class="muted">zsh modules, tmux base, nvim, git/delta</span>
        </div>
        <div class="layer-table__row">
          <span class="tone-blue text-mono">OS-native</span>
          <span><code>dotfiles-&#123;MacBook,Windows,Fedora,Arch,…&#125;</code></span>
          <span class="muted">package manager, clipboard shim, paths</span>
        </div>
        <div class="layer-table__row">
          <span class="tone-red text-mono">Role</span>
          <span><code>dotfiles-Kali</code> · <code>dotfiles-Defense</code></span>
          <span class="muted">offensive engagement (Kali) · defensive detection/hunt (Defense)</span>
        </div>
      </div>

      <!-- the subtree topology, drawn from the real repo list -->
      <h2 class="mt">The fleet at a glance</h2>
      <ArchitectureDiagram />

      <!-- how an OS repo consumes core -->
      <h2 class="mt">How an OS repo consumes Core</h2>
      <p>
        Each machine repo (except Windows, which replicates Core natively in PowerShell)
        vendors <code>dotfiles-core</code> under <code>core/</code> as a
        git subtree. That physically copies Core in and commits it, so the repo clones and
        works with no submodule flags — important, since these are public showcase repos
        people will browse.
      </p>
      <CommandBlock
        code={`# one-time, inside an OS repo:
git subtree add --prefix=core https://github.com/Gerrrt/dotfiles-core main --squash

# later, to pull Core updates down:
git subtree pull --prefix=core https://github.com/Gerrrt/dotfiles-core main --squash`}
      />
      <p class="muted">
        Maintainers fan a Core change out to every OS repo in one shot with
        <code>scripts/sync-core.sh</code>, which prints the exact short SHA each repo
        receives so a sync is traceable.
      </p>

      <!-- how it compares -->
      <h2 class="mt">How it compares — and when it's the wrong tool</h2>
      <p>
        Every dotfiles approach is a trade. This one optimizes for <strong>clone-and-go
        self-containment</strong> across many machines and a <strong>public, per-machine
        portfolio</strong> — paying a little vendored duplication for it. Here's how that
        lands against the usual alternatives, each of which wins in its own case.
      </p>
      <div class="grid grid-2">
        {
          comparisons.map((c) => (
            <article class="card">
              <h3>{c.title}</h3>
              <p style="margin:0;">{c.body}</p>
            </article>
          ))
        }
      </div>

      <div class="notforyou">
        <h3>When to reach for something else</h3>
        <p>A system that can't name its own constraints isn't worth trusting. Don't use this if:</p>
        <ul>
          {notForYou.map((n) => <li>{n}</li>)}
        </ul>
      </div>

      <!-- load order -->
      <h2 class="mt">The canonical load order</h2>
      <p>
        Load order is load-bearing. <code>tools</code> initializes atuin (registering its
        widget), <code>options</code> runs <code>compinit</code> (fzf-tab + carapace need
        it), and <code>fzf</code> defines its widgets <em>before</em> <code>plugins</code>
        loads zsh-vi-mode, whose init fires the keybinding hook in <code>bindings</code>.
        Every OS repo’s <code>.zshrc</code> sources the chain in this order:
      </p>
      <ol class="load-order">
        {
          loadOrder.map(([name, desc], i) => (
            <li>
              <span class="load-order__n text-mono">{String(i + 1).padStart(2, '0')}</span>
              <span class="load-order__name text-mono">{name}</span>
              <span class="load-order__desc muted">{desc}</span>
            </li>
          ))
        }
      </ol>

      <!-- kali note -->
      <div class="card kali-note">
        <h3 class="tone-red">The Kali role stage</h3>
        <p>
          Kali stacks three layers — Core, its apt OS layer, and an offensive role stage
          (<code>dotfiles-Defense</code> mirrors this on the blue side). Where a plain OS
          repo’s loader ends <code>… os local</code>, Kali inserts one more stage —
          <code>… os offensive local</code> — for engagement scaffolding (scope-first
          workspaces, an audit-trail <code>logshell</code>, NetExec/BloodHound CE helpers).
          Engagement data never lives in the repo; it stays under
          <code>~/engagements</code>, and every tool is for authorized engagements with
          written rules of engagement only.
        </p>
      </div>

      <!-- macOS desktop layer -->
      <h2 class="mt">The macOS desktop layer</h2>
      <p>
        OS-native layers own more than packages and paths. On macOS,
        <code>dotfiles-MacBook</code> commits a full tiling-desktop setup — window manager,
        menu bar, and keyboard — themed to Core’s tokyonight palette so the GUI reads as an
        extension of the terminal, not a separate world.
      </p>
      <div class="grid grid-3">
        {
          macDesktop.map((d) => (
            <article class="card">
              <h3 class:list={[`tone-${d.tone}`]}>
                <span class="text-mono">{d.icon}</span> {d.name}
              </h3>
              <p style="margin:0;">{d.body}</p>
            </article>
          ))
        }
      </div>

      <!-- deep dives -->
      <h2 class="mt">Deep dives</h2>
      <p>
        The design decisions above are documented in full inside the repos. These are the
        long-form references worth reading next:
      </p>
      <div class="grid grid-3">
        {
          deepDives.map((d) => (
            <a class="card deep-dive" href={d.href} target="_blank" rel="noopener">
              <span class="deep-dive__repo text-mono muted">{d.repo}</span>
              <h3>{d.title}</h3>
              <p>{d.body}</p>
              <span class="deep-dive__link">Read it ↗</span>
            </a>
          ))
        }
      </div>

      <div class="center" style="margin-top:3rem;">
        <a class="btn btn-primary" href={withBase('/getting-started')}>Install it →</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .mt {
    margin-top: 3.5rem;
  }
  .deep-dive {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
  }
  a.deep-dive:hover {
    color: inherit;
  }
  .deep-dive__repo {
    font-size: 0.72rem;
    letter-spacing: 0.03em;
  }
  .deep-dive h3 {
    margin: 0.4rem 0 0.5rem;
    font-size: 1.05rem;
  }
  .deep-dive p {
    font-size: 0.88rem;
    margin: 0 0 1rem;
  }
  .deep-dive__link {
    margin-top: auto;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--tn-cyan);
  }
  a.deep-dive:hover .deep-dive__link {
    color: var(--tn-blue);
  }
  .rule {
    margin: 0 0 1rem;
    padding: 1.5rem 1.75rem;
    border-left: 3px solid var(--tn-purple);
    background: linear-gradient(180deg, var(--tn-surface), var(--tn-bg-dark));
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  .rule p {
    margin: 0 0 0.5rem;
    color: var(--text-dim);
  }
  .rule em {
    color: var(--tn-cyan);
    font-style: italic;
  }
  .rule__punch {
    color: #fff !important;
    font-weight: 600;
    margin-top: 0.75rem !important;
  }
  .notforyou {
    margin: 1.5rem 0 0;
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--tn-orange);
    background: linear-gradient(180deg, var(--tn-surface), var(--tn-bg-dark));
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  .notforyou h3 {
    margin: 0 0 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--tn-orange);
  }
  .notforyou p {
    margin: 0 0 0.75rem;
    color: var(--text-dim);
  }
  .notforyou ul {
    margin: 0;
    padding-left: 1.1rem;
  }
  .notforyou li {
    margin: 0.4rem 0;
    color: var(--text-dim);
    line-height: 1.55;
  }

  .layer-table {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .layer-table__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.3rem;
    padding: 1rem 1.25rem;
    border-top: 1px solid var(--border);
    font-size: 0.92rem;
  }
  .layer-table__row:first-child {
    border-top: 0;
  }
  .layer-table__row--head {
    background: var(--tn-bg-dark);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }
  @media (min-width: 720px) {
    .layer-table__row {
      grid-template-columns: 0.8fr 1.6fr 1.4fr;
      gap: 1rem;
      align-items: center;
    }
  }

  .load-order {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .load-order li {
    display: grid;
    grid-template-columns: auto auto;
    gap: 0.15rem 1rem;
    align-items: center;
    padding: 0.7rem 1.1rem;
    border-top: 1px solid var(--border);
  }
  .load-order li:first-child {
    border-top: 0;
  }
  .load-order li:nth-child(odd) {
    background: rgba(255, 255, 255, 0.012);
  }
  .load-order__n {
    color: var(--text-muted);
    font-size: 0.8rem;
  }
  .load-order__name {
    color: var(--tn-cyan);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .load-order__desc {
    grid-column: 2;
    font-size: 0.85rem;
  }
  @media (min-width: 720px) {
    .load-order li {
      grid-template-columns: 2.5rem 9rem 1fr;
    }
    .load-order__desc {
      grid-column: auto;
    }
  }

  .kali-note {
    margin-top: 2rem;
    border-left: 3px solid var(--tn-red);
  }
  .kali-note h3 {
    margin-top: 0;
  }
  .kali-note p {
    margin: 0;
  }
</style>
