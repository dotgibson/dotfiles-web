---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Metrics from '../components/Metrics.astro';
import RepoCard from '../components/RepoCard.astro';
import CommandBlock from '../components/CommandBlock.astro';
import InstallBuilder from '../components/InstallBuilder.astro';
import { repos, layerMeta } from '../data/repos';
import { installer, installerOptions } from '../data/install';
import { getRepoLiveMap } from '../lib/github';
import { withBase } from '../lib/url';

// Absolute URLs to the static install endpoints, for copy/pastable one-liners.
const bashUrl = new URL(withBase(installer.bashPath), Astro.site).href;
const ps1Url = new URL(withBase(installer.ps1Path), Astro.site).href;

// The default command, rendered server-side so it's correct with JS disabled; the
// client script below keeps it in sync as checkboxes change.
const defaultModules = installerOptions
  .filter((o) => o.kind === 'module' && o.default)
  .map((o) => o.id)
  .join(',');
const defaultFlags = installerOptions
  .filter((o) => o.kind === 'flag' && o.default && o.flag)
  .map((o) => o.flag)
  .join(' ');
const defaultCommand = `curl -fsSL ${bashUrl} | bash -s -- --modules ${defaultModules}${
  defaultFlags ? ` ${defaultFlags}` : ''
}`;

// Live GitHub data for the cards, fetched once at build time. Best-effort: if the
// API is unreachable or rate-limited, this resolves to all-null and the cards just
// omit the live badges — the build never fails on it.
const live = await getRepoLiveMap(repos.map((r) => r.name));

const features = [
  {
    icon: '◆',
    accent: 'purple',
    title: 'Authored once, everywhere',
    body: 'Core lives in one repo and is vendored into every OS repo via git subtree. No N-way reconciliation, no drift — edit once, sync out.',
  },
  {
    icon: '⧉',
    accent: 'blue',
    title: 'Clone-and-go',
    body: 'Subtree vendors the actual files, so a fresh clone just works. No submodule init, no flags. Perfect for public portfolio repos.',
  },
  {
    icon: '⚡',
    accent: 'cyan',
    title: 'Same shell, every OS',
    body: 'The zsh module chain loads in one canonical order on macOS, Linux, and WSL — PowerShell mirrors it. Muscle memory transfers everywhere.',
  },
  {
    icon: '🛡',
    accent: 'green',
    title: 'Audited & benchmarked',
    body: 'A manifest-driven audit gate, hermetic behavioral tests, pinned plugin SHAs, and a startup-perf budget keep every sync honest.',
  },
  {
    icon: '◑',
    accent: 'orange',
    title: 'Three clean layers',
    body: 'Core (identical everywhere), OS-native (changes with the OS), and Role (offensive scaffolding for Kali). Every file has exactly one home.',
  },
  {
    icon: '⌘',
    accent: 'red',
    title: 'Discoverable by design',
    body: 'core-help cheat sheets, core-doctor health checks, did-you-mean command handling, and first-party completions for every verb.',
  },
];

const orderedRepos = [...repos];
---

<Base>
  <Hero />

  <Metrics />

  <!-- ===================================================== features -->
  <section class="section">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Why it’s built this way</span>
        <h2>A system, not a pile of config</h2>
        <p class="lead">
          Nine repositories, one philosophy: if it changes with the operating system it
          isn’t Core; if it changes with you as an operator it isn’t Core. Everything left
          over is Core — and it lives in exactly one place.
        </p>
      </div>

      <div class="grid grid-3">
        {
          features.map((f) => (
            <article class="card feature">
              <span class:list={['feature__icon', `tone-${f.accent}`]}>{f.icon}</span>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================================================== layers -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">The three-layer model</span>
        <h2>Core → OS-native → Role</h2>
        <p class="lead">
          Each layer answers a different question. Drawing the boundary precisely is what
          lets one Core serve every machine without special-casing.
        </p>
      </div>

      <div class="layers">
        {
          (['core', 'os', 'role'] as const).map((key, i) => {
            const l = layerMeta[key];
            const detail = {
              core: 'zsh modules, tmux base, Neovim, git, starship, mise, clip. Vendored into every OS repo under core/.',
              os: 'Package manager, paths, clipboard backend, OS tmux/git tweaks. One thin layer per platform.',
              role: 'Engagement scaffolding, scope-first workflow, offensive tooling. Stacked only on the Kali node.',
            }[key];
            return (
              <div class:list={['layer-row', `layer-row--${l.accent}`]}>
                <div class="layer-row__index text-mono">0{i + 1}</div>
                <div class="layer-row__main">
                  <h3 class:list={[`tone-${l.accent}`]}>{l.label}</h3>
                  <p>{detail}</p>
                </div>
                <div class="layer-row__meta muted">{l.desc}</div>
              </div>
            );
          })
        }
      </div>

      <div class="center" style="margin-top: 2.5rem;">
        <a class="btn btn-ghost" href={withBase('/architecture')}>Read the full architecture →</a>
      </div>
    </div>
  </section>

  <!-- ===================================================== repos -->
  <section class="section" id="repos">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">The fleet</span>
        <h2>Repository map</h2>
        <p class="lead">
          Nine repositories are public today — one Core, vendored into eight machine repos.
          Each card links straight to its repo, with live stars, last-push, and CI status
          pulled from GitHub at build time.
        </p>
      </div>

      <div class="grid grid-3">
        {orderedRepos.map((repo) => <RepoCard repo={repo} live={live[repo.name]} />)}
      </div>
    </div>
  </section>

  <!-- ===================================================== install CTA -->
  <section class="section section--alt">
    <div class="container install-cta">
      <div>
        <span class="eyebrow">Try it</span>
        <h2>Up and running in three commands</h2>
        <p class="lead">
          Pick your platform, clone, bootstrap. The installer is idempotent and ships a
          dry-run so you can preview every change before it touches your machine.
        </p>
        <div class="row" style="margin-top:1.5rem;">
          <a class="btn btn-primary" href={withBase('/getting-started')}>Full install guide →</a>
        </div>
      </div>
      <div class="install-cta__code">
        <InstallBuilder />
      </div>
    </div>
  </section>

  <!-- ===================================================== one-line installer -->
  <section class="section" id="one-liner">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">One-line installer</span>
        <h2>Build your install command</h2>
        <p class="lead">
          Prefer <code>curl … | bash</code>? Tick the components you want and copy the
          one-liner. It auto-detects your OS, clones the matching repo, and runs its
          bootstrap. Selection rides in as <strong>shell arguments</strong> — the script
          is static, so there’s no server doing the work, and you can read it first.
        </p>
      </div>

      <div class="builder" id="install-builder" data-bash-url={bashUrl}>
        <fieldset class="builder__opts">
          <legend>Components</legend>
          {
            installerOptions.map((o) => (
              <label class:list={['builder__opt', { 'is-locked': o.locked }]}>
                <input
                  type="checkbox"
                  data-id={o.id}
                  data-kind={o.kind}
                  data-flag={o.flag ?? ''}
                  checked={o.default || o.locked}
                  disabled={o.locked}
                />
                <span class="builder__opt-main">
                  <span class="builder__opt-label">
                    {o.label}
                    {o.locked && <span class="builder__opt-tag">always on</span>}
                  </span>
                  <span class="builder__opt-note">{o.note}</span>
                </span>
              </label>
            ))
          }
        </fieldset>

        <div class="builder__out">
          <CommandBlock code={defaultCommand} />
          <p class="muted builder__hint">
            Windows uses the PowerShell mirror:
            <code>irm {ps1Url} | iex</code>. Always review a piped script before running it
            — open either URL in your browser, or pipe it to <code>less</code> first.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .section--alt {
    background: var(--tn-bg-dark);
    border-block: 1px solid var(--border);
  }
  .feature {
    height: 100%;
  }
  .feature__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 10px;
    background: var(--tn-bg-dark);
    border: 1px solid var(--border);
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }
  .feature h3 {
    font-size: 1.1rem;
  }
  .feature p {
    font-size: 0.92rem;
    margin: 0;
  }

  .layers {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 880px;
    margin-inline: auto;
  }
  .layer-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1.25rem;
    align-items: start;
    padding: 1.4rem 1.5rem;
    background: linear-gradient(180deg, var(--tn-surface), var(--tn-bg-dark));
    border: 1px solid var(--border);
    border-left-width: 3px;
    border-radius: var(--radius);
  }
  .layer-row--purple {
    border-left-color: var(--tn-purple);
  }
  .layer-row--blue {
    border-left-color: var(--tn-blue);
  }
  .layer-row--red {
    border-left-color: var(--tn-red);
  }
  .layer-row__index {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-muted);
  }
  .layer-row__main h3 {
    margin: 0 0 0.35rem;
    font-size: 1.15rem;
  }
  .layer-row__main p {
    margin: 0;
    font-size: 0.92rem;
  }
  .layer-row__meta {
    grid-column: 2;
    font-size: 0.82rem;
    font-family: var(--font-mono);
  }
  @media (min-width: 760px) {
    .layer-row {
      grid-template-columns: auto 1.4fr 1fr;
      align-items: center;
    }
    .layer-row__meta {
      grid-column: auto;
      text-align: right;
    }
  }

  .install-cta {
    display: grid;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 900px) {
    .install-cta {
      grid-template-columns: 1fr 1.1fr;
    }
  }

  .builder {
    display: grid;
    gap: 2rem;
    max-width: 980px;
    margin-inline: auto;
    align-items: start;
  }
  @media (min-width: 860px) {
    .builder {
      grid-template-columns: 0.9fr 1.1fr;
    }
  }
  .builder__opts {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--tn-bg-dark);
    padding: 1.25rem 1.4rem;
    margin: 0;
  }
  .builder__opts legend {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    padding: 0 0.4rem;
  }
  .builder__opt {
    display: flex;
    gap: 0.8rem;
    padding: 0.7rem 0;
    cursor: pointer;
    border-top: 1px solid var(--border);
  }
  .builder__opt:first-of-type {
    border-top: 0;
  }
  .builder__opt.is-locked {
    cursor: default;
    opacity: 0.85;
  }
  .builder__opt input {
    margin-top: 0.2rem;
    width: 1.05rem;
    height: 1.05rem;
    accent-color: var(--tn-purple);
    flex: none;
  }
  .builder__opt-main {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .builder__opt-label {
    font-weight: 600;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .builder__opt-tag {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--tn-cyan);
    border: 1px solid var(--tn-border-bright);
    border-radius: 999px;
    padding: 0.05rem 0.45rem;
  }
  .builder__opt-note {
    font-size: 0.84rem;
    color: var(--text-dim);
  }
  .builder__hint {
    font-size: 0.82rem;
    margin: 0.9rem 0 0;
  }
  .builder__hint code {
    word-break: break-all;
  }
</style>

<script>
  // Keep the one-line install command in sync with the component checkboxes.
  // Pure string assembly on the client — there is no live API; the selection
  // becomes SHELL ARGUMENTS the operator runs locally. Mirrors the getting-started
  // version switcher: update the visible per-line span AND the copy button's
  // data-code (Base.astro's copy handler reads that attribute).
  const builder = document.getElementById('install-builder');
  if (builder) {
    const bashUrl = builder.dataset.bashUrl ?? '/install';
    const boxes = Array.from(builder.querySelectorAll<HTMLInputElement>('input[type=checkbox]'));
    const block = builder.querySelector<HTMLElement>('.codeblock');
    const textSpan = block?.querySelector<HTMLElement>('.cb-text') ?? null;
    const copyBtn = block?.querySelector<HTMLButtonElement>('[data-copy]') ?? null;

    // Defense-in-depth, in the same spirit as src/data/site.ts's REF_PATTERN but
    // deliberately STRICTER: module ids are simple tokens, so this set omits the
    // slash that REF_PATTERN allows for git refs. Only validated tokens reach the
    // generated command line, so a future option id can't smuggle in metacharacters.
    const TOKEN_OK = /^[A-Za-z0-9._-]+$/;

    const build = (): string => {
      const modules: string[] = [];
      const flags: string[] = [];
      for (const b of boxes) {
        if (!b.checked) continue;
        const id = b.dataset.id ?? '';
        if (b.dataset.kind === 'module' && TOKEN_OK.test(id)) {
          modules.push(id);
        } else if (b.dataset.kind === 'flag' && b.dataset.flag) {
          flags.push(b.dataset.flag);
        }
      }
      if (modules.length === 0) modules.push('core'); // core is locked-on; belt and braces
      const tail = flags.length ? ` ${flags.join(' ')}` : '';
      return `curl -fsSL ${bashUrl} | bash -s -- --modules ${modules.join(',')}${tail}`;
    };

    const render = () => {
      const cmd = build();
      if (textSpan) textSpan.textContent = cmd;
      if (copyBtn) copyBtn.setAttribute('data-code', cmd);
    };

    boxes.forEach((b) => b.addEventListener('change', render));
    render();
  }
</script>
