---
import Base from '../layouts/Base.astro';
import CommandBlock from '../components/CommandBlock.astro';
import { platforms } from '../data/install';
import { site, release } from '../data/site';

// The channels to offer. Always include `current` so a config where `current` is
// a tag but `channels` wasn't updated still surfaces (and pins) that version
// instead of silently showing a pinned badge over main-only commands.
const channels = release.channels.includes(release.current)
  ? [...release.channels]
  : [release.current, ...release.channels];
// Show the dropdown when there's a real choice OR we're pinned to a non-main
// release; otherwise the static rolling pill is enough.
const showSelect = channels.length > 1 || release.current !== 'main';
---

<Base
  title="Get Started"
  description="Install the dotfiles ecosystem on macOS, Windows, Kali (WSL2), or Linux. Clone, preview with a dry run, then bootstrap."
>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Getting started</span>
        <h1>Install in three commands</h1>
        <p class="lead">
          Every repo follows the same shape: <strong>clone</strong>, optionally
          <strong>dry-run</strong> to preview the symlink plan, then
          <strong>bootstrap</strong>. Core is vendored, so a clone is self-contained — no
          submodule flags. Pick your platform below.
        </p>
      </div>

      <!-- prerequisites -->
      <div class="card prereq">
        <h3>Before you start</h3>
        <ul>
          <li><code>git</code> installed and your identity ready (name + email).</li>
          <li><strong>macOS:</strong> Command Line Tools (the bootstrap installs Homebrew).</li>
          <li><strong>Windows:</strong> PowerShell 7 (<code>pwsh</code>) and Developer Mode (or run elevated) so symlinks work.</li>
          <li><strong>Kali:</strong> running under WSL2; engagement data is kept out of the repo by design.</li>
        </ul>
      </div>

      <!-- version channel switcher -->
      <div class="card verbar">
        <div class="verbar__copy">
          <h3>Version</h3>
          <p class="muted">
            Pick a release to pin the commands below. Tagged releases are
            <strong>hermetic</strong> — Core is vendored, so an older tag installs exactly
            what it shipped with. <code>main</code> tracks the latest commit.
          </p>
        </div>
        {
          showSelect ? (
            <label class="verselect">
              <select id="version-select" aria-label="Release version">
                {channels.map((c) => (
                  <option value={c} selected={c === release.current}>
                    {c === 'main' ? 'main · rolling (latest commit)' : c}
                  </option>
                ))}
              </select>
            </label>
          ) : (
            <span class="badge tone-cyan">
              <span class="dot" />
              {release.current === 'main' ? 'main · rolling' : release.current}
            </span>
          )
        }
      </div>

      <!-- platform tabs -->
      <div class="tabs" id="install-tabs" data-default-ref={release.current}>
        <div class="tabs__list" role="tablist" aria-label="Platform">
          {
            platforms.map((p, i) => (
              <button
                role="tab"
                id={`tab-${p.id}`}
                class:list={['tabs__tab', { active: i === 0 }]}
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`panel-${p.id}`}
                data-tab={p.id}
              >
                {p.label}
              </button>
            ))
          }
        </div>

        {
          platforms.map((p, i) => (
            <div
              role="tabpanel"
              id={`panel-${p.id}`}
              class:list={['tabs__panel', { active: i === 0 }]}
              aria-labelledby={`tab-${p.id}`}
              hidden={i !== 0}
              data-panel={p.id}
            >
              <div class="panel-head">
                <div>
                  <h2>{p.label}</h2>
                  <p class="lead">{p.intro}</p>
                </div>
                {p.available ? (
                  <a class="btn btn-ghost" href={`${site.githubBase}/${p.repo}`} target="_blank" rel="noopener">
                    {p.repo} ↗
                  </a>
                ) : (
                  <span class="badge tone-orange"><span class="dot" />In progress</span>
                )}
              </div>

              <ol class="steps">
                {p.steps.map((step) => (
                  <li class="step">
                    <h3 class="step__title">{step.title}</h3>
                    {step.body && <p class="step__body">{step.body}</p>}
                    {step.code && <CommandBlock code={step.code} lang={step.lang ?? 'bash'} />}
                  </li>
                ))}
              </ol>
            </div>
          ))
        }
      </div>

      <!-- updating core -->
      <div class="card afterword">
        <h3>Keeping Core current</h3>
        <p>
          Core is authored in <code>dotfiles-core</code> and vendored into every OS repo. To
          pull the latest Core into a machine repo and re-wire links:
        </p>
        <CommandBlock
          code={`git subtree pull --prefix=core https://github.com/Gerrrt/dotfiles-core main --squash
./bootstrap.sh --links-only`}
        />
        <p class="muted" style="margin-bottom:0;">
          Tracking a pinned release instead? Re-clone the new tag (or
          <code>git fetch --tags && git checkout vX.Y.Z</code>) — the vendored Core moves
          with it. Maintainers can fan a Core change out to every OS repo at once with
          <code>scripts/sync-core.sh</code> from <code>dotfiles-core</code>.
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .prereq {
    margin-bottom: 1.5rem;
  }
  .prereq h3 {
    margin-top: 0;
  }
  .prereq ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--text-dim);
  }
  .prereq li {
    margin-bottom: 0.4rem;
  }

  .verbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .verbar h3 {
    margin: 0 0 0.3rem;
  }
  .verbar__copy {
    max-width: 60ch;
  }
  .verbar__copy .muted {
    margin: 0;
    font-size: 0.92rem;
  }
  .verselect select {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--tn-fg);
    background: var(--tn-bg-dark);
    border: 1px solid var(--tn-border-bright);
    border-radius: 8px;
    padding: 0.55rem 0.8rem;
    cursor: pointer;
  }

  #install-command-builder {
    margin-bottom: 2.5rem;
  }

  .tabs__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.4rem;
    background: var(--tn-bg-dark);
    border: 1px solid var(--border);
    border-radius: 12px;
    margin-bottom: 2rem;
  }
  .tabs__tab {
    flex: 1 1 auto;
    min-width: max-content;
    padding: 0.6rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-dim);
    background: transparent;
    border: 1px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .tabs__tab:hover {
    color: #fff;
  }
  .tabs__tab.active {
    color: #10131f;
    background: linear-gradient(135deg, var(--tn-blue), var(--tn-purple));
  }
  .tabs__panel {
    animation: fade 0.25s ease;
  }
  .tabs__panel[hidden] {
    display: none;
  }
  @keyframes fade {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
  }
  .panel-head {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }
  .panel-head h2 {
    margin-bottom: 0.4rem;
  }
  .panel-head .lead {
    max-width: 60ch;
    margin: 0;
  }

  .steps {
    list-style: none;
    counter-reset: step;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .step {
    counter-increment: step;
    position: relative;
    padding-left: 3rem;
  }
  .step::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0;
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--tn-cyan);
    background: var(--tn-bg-dark);
    border: 1px solid var(--tn-border-bright);
    border-radius: 999px;
  }
  .step__title {
    font-size: 1.05rem;
    margin: 0.25rem 0 0.4rem;
  }
  .step__body {
    font-size: 0.92rem;
    margin-bottom: 0.75rem;
  }
  .afterword {
    margin-top: 3rem;
  }
  .afterword h3 {
    margin-top: 0;
  }
  @media (max-width: 520px) {
    .step {
      padding-left: 2.5rem;
    }
  }
</style>

<script>
  // Tab switching for the platform panels.
  const root = document.getElementById('install-tabs');
  if (root) {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-tab]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-panel]'));
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.tab;
        tabs.forEach((t) => {
          const on = t === tab;
          t.classList.toggle('active', on);
          t.setAttribute('aria-selected', String(on));
        });
        panels.forEach((p) => {
          const on = p.dataset.panel === id;
          p.classList.toggle('active', on);
          p.hidden = !on;
        });
      });
    });
  }
</script>

<script>
  // Version switcher: rewrite every install command's clone ref to the selected
  // release. Line-local and generic — only `git clone …Gerrrt/…` lines and the
  // Windows `irm …/raw.githubusercontent.com/Gerrrt/<repo>/<ref>/…` one-liner are
  // touched, so curated prose on every other line is left alone. Operates on the
  // per-line spans CommandBlock renders and keeps each copy button's data-code in
  // sync (Base.astro's copy handler reads that attribute).
  const tabsRoot = document.getElementById('install-tabs');
  const sel = document.getElementById('version-select') as HTMLSelectElement | null;
  const defaultRef = tabsRoot?.getAttribute('data-default-ref') || 'main';

  // Same strictness as src/data/site.ts's REF_PATTERN — never inject an unvalidated
  // ref into a copy/pastable command, even though the build-time check should have
  // already rejected a bad one.
  const REF_OK = /^[A-Za-z0-9._/-]+$/;

  const pinClone = (text: string, ref: string): string => {
    if (ref !== 'main' && !REF_OK.test(ref)) return text;
    let out = text.replace(
      /\bgit clone\s+(?:--branch\s+\S+\s+)?(https:\/\/github\.com\/Gerrrt\/\S+)/g,
      ref === 'main' ? 'git clone $1' : `git clone --branch ${ref} $1`
    );
    // Replace the ref SEGMENT after the repo (works for main, v-tags, or any
    // other ref), since the pristine source always carries the rolling 'main'.
    out = out.replace(
      /(raw\.githubusercontent\.com\/Gerrrt\/[^/]+\/)[^/\s]+/g,
      `$1${ref}`
    );
    return out;
  };

  const apply = (ref: string) => {
    document.querySelectorAll<HTMLElement>('#install-tabs .codeblock').forEach((block) => {
      block.querySelectorAll<HTMLElement>('.cb-text').forEach((span) => {
        if (span.dataset.orig === undefined) span.dataset.orig = span.textContent ?? '';
        span.textContent = pinClone(span.dataset.orig, ref);
      });
      const btn = block.querySelector<HTMLButtonElement>('[data-copy]');
      if (btn) {
        if (btn.dataset.codeOrig === undefined)
          btn.dataset.codeOrig = btn.getAttribute('data-code') ?? '';
        btn.setAttribute('data-code', pinClone(btn.dataset.codeOrig, ref));
      }
    });
  };

  if (sel) {
    apply(sel.value);
    sel.addEventListener('change', () => apply(sel.value));
  } else if (defaultRef !== 'main') {
    apply(defaultRef);
  }
</script>
