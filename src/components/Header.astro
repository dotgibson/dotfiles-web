---
import { nav, site, coreRepoUrl } from '../data/site';
import { metrics } from '../data/metrics';
import { withBase } from '../lib/url';

const current = Astro.url.pathname.replace(/\/$/, '');
function isActive(href: string) {
  if (href.startsWith('/#')) return false;
  const target = withBase(href).replace(/\/$/, '');
  return current === target;
}
// A group is highlighted when the current page is one of its children.
function groupActive(children: readonly { href: string }[]) {
  return children.some((c) => isActive(c.href));
}

// The Core version this build documents (from generated.json) — surfaced as a
// badge so the site self-identifies which release it reflects. Null-safe: hidden
// if the snapshot has no version stamp.
const coreVersion = metrics.core.version;
---

<header class="site-header" id="top">
  <div class="container site-header__inner">
    <div class="brand-wrap">
      <a class="brand" href={withBase('/')}>
        <img class="brand__mark" src={withBase('/logo.svg')} alt="" width="26" height="26" decoding="async" />
        <span class="brand__name">{site.name}</span>
        <span class="brand__cursor"></span>
      </a>
      {
        coreVersion && (
          <a
            class="ver"
            href={withBase('/changelog')}
            title="Core version this site documents — view the changelog"
          >
            core {coreVersion}
          </a>
        )
      }
    </div>

    <nav class="nav" aria-label="Primary">
      <ul class="nav__list" id="nav-list">
        {
          nav.map((item) =>
            'children' in item ? (
              <li class="nav__group">
                <button
                  type="button"
                  class:list={['nav__link', 'nav__trigger', { active: groupActive(item.children) }]}
                  aria-expanded="false"
                  aria-haspopup="true"
                >
                  {item.label}
                  <span class="nav__caret" aria-hidden="true">▾</span>
                </button>
                <ul class="nav__menu">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={withBase(child.href)}
                        class:list={['nav__sublink', { active: isActive(child.href) }]}
                        aria-current={isActive(child.href) ? 'page' : undefined}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </li>
            ) : (
              <li>
                <a
                  href={withBase(item.href)}
                  class:list={['nav__link', { active: isActive(item.href) }]}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ),
          )
        }
        <li class="nav__cta">
          <a class="btn btn-ghost" href={coreRepoUrl} target="_blank" rel="noopener">
            GitHub ↗
          </a>
        </li>
      </ul>
    </nav>

    <button class="nav__toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-list" id="nav-toggle">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    background: rgba(22, 22, 30, 0.72);
    border-bottom: 1px solid var(--border);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }
  .brand-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.05rem;
    color: #fff;
  }
  .brand__mark {
    width: 1.6rem;
    height: 1.6rem;
    display: block;
    margin-right: 0.3rem;
    border-radius: 6px;
  }
  .brand__name {
    color: var(--tn-fg);
  }
  .brand__cursor {
    width: 0.5rem;
    height: 1rem;
    background: var(--tn-cyan);
    margin-left: 0.15rem;
    animation: blink 1.1s steps(2, start) infinite;
  }
  .ver {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1;
    color: var(--text-dim);
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    white-space: nowrap;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .ver:hover {
    color: #fff;
    border-color: var(--tn-border-bright);
  }
  .nav__list {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav__link {
    display: block;
    padding: 0.45rem 0.8rem;
    border-radius: 8px;
    color: var(--text-dim);
    font-size: 0.92rem;
    font-weight: 500;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav__link:hover {
    color: #fff;
    background: var(--tn-surface);
  }
  .nav__link.active {
    color: var(--tn-cyan);
    background: var(--tn-surface);
  }

  /* Dropdown groups (Tools / Learn) */
  .nav__group {
    position: relative;
  }
  .nav__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: none;
    border: none;
    cursor: pointer;
    font: inherit;
  }
  .nav__caret {
    font-size: 0.6rem;
    line-height: 1;
    transition: transform 0.15s ease;
  }
  .nav__group:hover .nav__caret,
  .nav__group:focus-within .nav__caret,
  .nav__group.open .nav__caret {
    transform: rotate(180deg);
  }
  .nav__menu {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    min-width: 11rem;
    list-style: none;
    margin: 0;
    padding: 0.35rem;
    background: rgba(22, 22, 30, 0.98);
    border: 1px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s ease;
    z-index: 110;
  }
  .nav__group:hover .nav__menu,
  .nav__group:focus-within .nav__menu,
  .nav__group.open .nav__menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav__sublink {
    display: block;
    padding: 0.45rem 0.7rem;
    border-radius: 7px;
    color: var(--text-dim);
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav__sublink:hover {
    color: #fff;
    background: var(--tn-surface);
  }
  .nav__sublink.active {
    color: var(--tn-cyan);
    background: var(--tn-surface);
  }
  .nav__cta {
    margin-left: 0.5rem;
  }
  .nav__cta .btn {
    padding: 0.45rem 0.9rem;
    font-size: 0.85rem;
  }
  .nav__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.6rem;
    height: 2.6rem;
    background: var(--tn-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    cursor: pointer;
  }
  .nav__toggle span {
    display: block;
    width: 1.1rem;
    height: 2px;
    margin-inline: auto;
    background: var(--tn-fg);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav__toggle[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav__toggle[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .nav__toggle[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 820px) {
    .nav__toggle {
      display: flex;
    }
    .nav__list {
      position: fixed;
      inset: 4rem 0 auto 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
      padding: 1rem clamp(1rem, 4vw, 2rem) 1.5rem;
      background: rgba(22, 22, 30, 0.98);
      border-bottom: 1px solid var(--border);
      transform: translateY(-120%);
      transition: transform 0.25s ease;
    }
    .nav__list.open {
      transform: translateY(0);
    }
    .nav__link {
      padding: 0.7rem 0.8rem;
      font-size: 1rem;
    }
    /* Groups become click-to-open accordions inside the mobile panel. */
    .nav__group {
      position: static;
    }
    .nav__trigger {
      width: 100%;
      justify-content: space-between;
      padding: 0.7rem 0.8rem;
    }
    .nav__menu {
      position: static;
      min-width: 0;
      padding: 0 0 0.35rem 0.5rem;
      background: none;
      border: none;
      box-shadow: none;
      /* Hidden until the trigger toggles `.open`; the transient reveal transition
         is dropped on mobile so the accordion snaps rather than slides sideways. */
      transform: none;
      transition: none;
    }
    .nav__sublink {
      padding: 0.6rem 0.8rem;
      font-size: 1rem;
    }
    .nav__cta {
      margin: 0.5rem 0 0;
    }
    .nav__cta .btn {
      width: 100%;
      justify-content: center;
    }
  }
  @media (max-width: 520px) {
    .ver {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const list = document.getElementById('nav-list');
  if (toggle && list) {
    toggle.addEventListener('click', () => {
      const open = list.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(open));
    });
    list.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        list.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      })
    );
  }

  // Dropdown groups: click-toggle with aria-expanded in sync. Desktop pointer
  // users still get hover/focus reveal purely from CSS; this makes the groups
  // work for keyboard and touch, and keeps only one open at a time.
  const groups = Array.from(document.querySelectorAll<HTMLElement>('.nav__group'));
  function closeGroups(except?: HTMLElement) {
    groups.forEach((g) => {
      if (g === except) return;
      g.classList.remove('open');
      g.querySelector('.nav__trigger')?.setAttribute('aria-expanded', 'false');
    });
  }
  groups.forEach((group) => {
    const trigger = group.querySelector<HTMLButtonElement>('.nav__trigger');
    if (!trigger) return;
    trigger.addEventListener('click', () => {
      const open = group.classList.toggle('open');
      trigger.setAttribute('aria-expanded', String(open));
      if (open) closeGroups(group);
    });
  });
  // Dismiss open dropdowns on outside click or Escape.
  document.addEventListener('click', (e) => {
    if (!(e.target instanceof Node) || !e.target.parentElement) return;
    if (!(e.target as Element).closest?.('.nav__group')) closeGroups();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeGroups();
  });
</script>
