---
// One-line install builder, driven entirely by the shared installer definitions in
// src/data/install.ts (`installer` + `installerOptions`) — the SAME source of truth
// the home page's builder uses, so the two can never disagree about which modules or
// flags exist. Toggle components → get the exact `curl … | bash -s -- --modules …`
// command for the static /install launcher.
//
// Why this is safe: GitHub Pages is static, so selection rides in as SHELL ARGUMENTS
// the operator runs locally, never a server-reflected query string. Only validated
// tokens from installerOptions reach the command line (see TOKEN_OK below).
import { installer, installerOptions } from '../data/install';
import { withBase } from '../lib/url';

// Absolute URLs so a copied command works pasted into any terminal (matches the
// home-page builder).
const bashUrl = new URL(withBase(installer.bashPath), Astro.site).href;
const ps1Url = new URL(withBase(installer.ps1Path), Astro.site).href;

const modules = installerOptions.filter((o) => o.kind === 'module');
const flags = installerOptions.filter((o) => o.kind === 'flag');

const defaultModules = modules
  .filter((o) => o.default)
  .map((o) => o.id)
  .join(',');
const defaultFlags = flags
  .filter((o) => o.default && o.flag)
  .map((o) => o.flag)
  .join(' ');
const defaultCommand = `curl -fsSL ${bashUrl} | bash -s -- --modules ${defaultModules}${
  defaultFlags ? ` ${defaultFlags}` : ''
}`;
---

<div class="icbuilder card" id="install-command-builder" data-bash-url={bashUrl}>
  <div class="icbuilder__head">
    <span class="icbuilder__pulse" aria-hidden="true"></span>
    <div>
      <h3>Build your one-line install</h3>
      <p class="muted">
        Tick the components you want and copy the command. Yes — this streams the script
        from the URL straight into your shell, so read it first (pipe it to <code>less</code>).
        What’s safe here: your selection is just local shell arguments, and nothing is
        reflected or executed server-side. Prefer not to pipe? Clone the repo and run its
        bootstrap instead — same result, fully transparent.
      </p>
    </div>
  </div>

  <fieldset class="icbuilder__opts">
    <legend class="sr-only">Install components</legend>
    {
      installerOptions.map((o) => (
        <label class="icrow">
          <input
            type="checkbox"
            data-id={o.id}
            data-kind={o.kind}
            data-flag={o.flag ?? ''}
            checked={o.default}
            disabled={o.locked}
          />
          <span class="icrow__body">
            <span class="icrow__label">
              {o.label}
              {o.locked && <span class="badge tone-cyan"><span class="dot" />always on</span>}
              {o.kind === 'flag' && <code>{o.flag}</code>}
            </span>
            <span class="icrow__note">{o.note}</span>
          </span>
        </label>
      ))
    }
  </fieldset>

  <div class="codeblock icbuilder__out">
    <button class="copy" type="button" data-copy data-code={defaultCommand} aria-label="Copy install command">copy</button>
    <pre aria-live="polite"><code><span class="cb-prompt">$ </span><span class="cb-text">{defaultCommand}</span></code></pre>
  </div>

  <p class="icbuilder__win muted">
    On Windows the host install is a single unit (no module picker):
    <code>irm {ps1Url} | iex</code>. Always review a piped script before running it —
    <code>curl -fsSL {bashUrl} | less</code>.
  </p>
</div>

<style>
  .icbuilder {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .icbuilder__head {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .icbuilder__pulse {
    margin-top: 0.45rem;
    width: 0.6rem;
    height: 0.6rem;
    flex: none;
    border-radius: 999px;
    background: var(--tn-green);
    box-shadow: 0 0 0 0 rgba(158, 206, 106, 0.6);
    animation: icPulse 1.8s ease-out infinite;
  }
  @keyframes icPulse {
    to {
      box-shadow: 0 0 0 0.55rem rgba(158, 206, 106, 0);
    }
  }
  .icbuilder__head h3 {
    margin: 0 0 0.25rem;
    font-size: 1.05rem;
  }
  .icbuilder__head .muted {
    margin: 0;
    font-size: 0.88rem;
    max-width: 64ch;
  }

  .icbuilder__opts {
    border: 0;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .icrow {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--tn-bg-dark);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .icrow:hover {
    border-color: var(--tn-border-bright);
  }
  .icrow:has(input:checked) {
    border-color: var(--tn-border-bright);
    background: var(--tn-surface);
  }
  .icrow:has(input:disabled) {
    cursor: default;
    opacity: 0.92;
  }
  .icrow:focus-within {
    outline: 2px solid var(--tn-blue);
    outline-offset: 2px;
  }
  .icrow input {
    margin-top: 0.2rem;
    width: 1.05rem;
    height: 1.05rem;
    accent-color: var(--tn-green);
    flex: none;
    cursor: pointer;
  }
  .icrow input:disabled {
    cursor: default;
  }
  .icrow__body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .icrow__label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-weight: 600;
    color: #fff;
  }
  .icrow__label code {
    font-family: var(--font-mono);
    font-size: 0.82em;
    color: var(--tn-green);
  }
  .icrow__note {
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  .icbuilder__out {
    margin: 0;
  }
  .icbuilder__out .cb-prompt {
    color: var(--tn-green);
    user-select: none;
  }
  .icbuilder__out code {
    word-break: break-all;
  }
  .icbuilder__win {
    margin: 0;
    font-size: 0.82rem;
  }
  .icbuilder__win code {
    word-break: break-all;
  }
</style>

<script>
  // Reassemble the one-liner from the checkbox state. Mirrors the home page builder's
  // logic and the same strict token allowlist, so only validated module ids ever land
  // on the command line.
  const root = document.getElementById('install-command-builder');
  if (root) {
    const bashUrl = root.dataset.bashUrl ?? '/install';
    const boxes = Array.from(root.querySelectorAll<HTMLInputElement>('input[type=checkbox]'));
    const block = root.querySelector<HTMLElement>('.codeblock');
    const textSpan = block?.querySelector<HTMLElement>('.cb-text') ?? null;
    const copyBtn = block?.querySelector<HTMLButtonElement>('[data-copy]') ?? null;

    // Stricter than site.ts's REF_PATTERN — module ids are simple tokens, no slash.
    const TOKEN_OK = /^[A-Za-z0-9._-]+$/;

    const build = (): string => {
      const modules: string[] = [];
      const flags: string[] = [];
      for (const b of boxes) {
        if (!b.checked) continue;
        const id = b.dataset.id ?? '';
        if (b.dataset.kind === 'module' && TOKEN_OK.test(id)) modules.push(id);
        else if (b.dataset.kind === 'flag' && b.dataset.flag) flags.push(b.dataset.flag);
      }
      if (modules.length === 0) modules.push('core'); // core is locked-on; belt and braces
      const tail = flags.length ? ` ${flags.join(' ')}` : '';
      return `curl -fsSL ${bashUrl} | bash -s -- --modules ${modules.join(',')}${tail}`;
    };

    const render = () => {
      const cmd = build();
      if (textSpan) textSpan.textContent = cmd;
      if (copyBtn) copyBtn.setAttribute('data-code', cmd);
    };

    boxes.forEach((b) => b.addEventListener('change', render));
    render();
  }
</script>
