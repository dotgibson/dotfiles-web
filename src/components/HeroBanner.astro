---
/*
 * HeroBanner.astro — a framed Neovim editor mockup, NvChad's hero-banner content format.
 *
 * NvChad's landing is anchored by one big screenshot of the styled editor. This renders
 * the same idea in pure HTML/CSS (no screenshot, no Nerd Font needed) and — the honest
 * part — it depicts the ACTUAL styling shipped to dotfiles-core: the rounded-block
 * lualine statusline, the flat NvChad tabline, and Tokyo Night palette syntax. The
 * rounded statusline caps are CSS `border-radius`, not Nerd-Font glyphs, so it renders
 * identically in every browser. Decorative → the whole figure is aria-hidden.
 *
 * The code lines are built as an HTML string and rendered via set:html so the literal
 * Lua braces (`{ fg = c.border }`) aren't parsed as Astro expressions.
 */
const codeHtml = [
  '<span class="ln"> 1</span><span class="c-cm">-- tokyonight: the fleet-wide palette</span>',
  '<span class="ln"> 2</span><span class="c-fn">require</span><span class="c-fg">(</span><span class="c-str">"tokyonight"</span><span class="c-fg">).</span><span class="c-fn">setup</span><span class="c-fg">({</span>',
  '<span class="ln cur"> 3</span><span class="c-kw">  style</span><span class="c-fg"> = </span><span class="c-str">"storm"</span><span class="c-fg">,</span>',
  '<span class="ln"> 4</span><span class="c-kw">  transparent</span><span class="c-fg"> = </span><span class="c-cn">true</span><span class="c-fg">,</span>',
  '<span class="ln"> 5</span><span class="c-kw">  on_highlights</span><span class="c-fg"> = </span><span class="c-kw">function</span><span class="c-fg">(hl, c)</span>',
  '<span class="ln sg"> 6</span><span class="c-fg">    hl.</span><span class="c-ty">WinSeparator</span><span class="c-fg"> = { fg = c.</span><span class="c-nm">border</span><span class="c-fg"> }</span>',
  '<span class="ln"> 7</span><span class="c-kw">  end</span><span class="c-fg">,</span>',
  '<span class="ln"> 8</span><span class="c-fg">})</span>',
].join('\n');
---

<!-- a plain <div>, not <section>: this banner is purely decorative, so it must not
     be an (unnamed) sectioning landmark. The figure itself is aria-hidden below. -->
<div class="hb">
  <div class="container">
    <div class="hb__frame" aria-hidden="true">
      <!-- window chrome -->
      <div class="hb__bar">
        <span class="hb__dot hb__dot--r"></span>
        <span class="hb__dot hb__dot--y"></span>
        <span class="hb__dot hb__dot--g"></span>
        <span class="hb__title">nvim — ~/dotfiles-core</span>
      </div>

      <!-- tabline: flat NvChad tabs -->
      <div class="hb__tabs">
        <span class="hb__tab">init.lua</span>
        <span class="hb__tab hb__tab--active">theme.lua</span>
        <span class="hb__tab">lualine.lua<span class="hb__mod">●</span></span>
        <span class="hb__tabs-fill"></span>
        <span class="hb__tab hb__tab--ghost">tabs</span>
      </div>

      <!-- editor body: gutter + syntax-highlighted Lua -->
      <div class="hb__body">
        <pre class="hb__code"><code set:html={codeHtml}></code></pre>
      </div>

      <!-- statusline: the rounded NvChad blocks (border-radius, not glyphs) -->
      <div class="hb__stl">
        <span class="stl-blk stl-mode">NORMAL</span>
        <span class="stl-blk stl-git">
          <svg class="stl-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="2.5"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="8" r="2.5"/><path d="M18 10.5v1a3 3 0 0 1-3 3H8.5"/><path d="M6 8.5v7"/></svg>main
        </span>
        <span class="stl-blk stl-file">theme.lua</span>
        <span class="stl-fill"></span>
        <span class="stl-blk stl-diag"><span class="d-err">✗ 1</span><span class="d-warn">● 2</span></span>
        <span class="stl-blk stl-lsp">LSP ~ lua_ls</span>
        <span class="stl-blk stl-cwd">dotfiles-core</span>
        <span class="stl-blk stl-loc">3:2</span>
      </div>
    </div>
  </div>
</div>

<style>
  .hb {
    padding-block: 0 clamp(2rem, 6vw, 4rem);
  }
  /* the soft glow NvChad hero banners sit on */
  .hb__frame {
    position: relative;
    max-width: 960px;
    margin-inline: auto;
    border: 1px solid var(--tn-border-bright);
    border-radius: 14px;
    overflow: hidden;
    background: var(--tn-bg);
    box-shadow:
      0 30px 80px -40px rgba(0, 0, 0, 0.9),
      0 0 0 1px rgba(255, 255, 255, 0.02) inset;
    font-family: var(--font-mono);
  }
  .hb__frame::before {
    content: '';
    position: absolute;
    inset: -40% -10% auto;
    height: 60%;
    background: radial-gradient(60% 100% at 50% 0%, color-mix(in srgb, var(--tn-blue) 22%, transparent), transparent 70%);
    pointer-events: none;
  }

  /* window bar */
  .hb__bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 0.9rem;
    background: var(--tn-bg-dark);
    border-bottom: 1px solid var(--border);
  }
  .hb__dot {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
  }
  .hb__dot--r { background: var(--tn-red); }
  .hb__dot--y { background: var(--tn-yellow); }
  .hb__dot--g { background: var(--tn-green); }
  .hb__title {
    margin-left: 0.5rem;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  /* tabline */
  .hb__tabs {
    display: flex;
    align-items: stretch;
    gap: 1px;
    background: var(--tn-bg-dark);
    font-size: 0.78rem;
    border-bottom: 1px solid var(--border);
  }
  .hb__tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    color: var(--text-muted);
    background: var(--tn-bg-dark);
  }
  .hb__tab--active {
    color: #fff;
    background: var(--tn-bg);
    box-shadow: inset 0 -2px 0 var(--tn-blue);
  }
  .hb__mod { color: var(--tn-green); font-size: 0.6rem; }
  .hb__tabs-fill { flex: 1; }
  .hb__tab--ghost {
    color: var(--tn-fg);
    background: var(--tn-surface-2);
  }

  /* code body */
  .hb__body {
    background: var(--tn-bg);
    padding: 0.6rem 0;
    overflow-x: auto;
  }
  .hb__code {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.75;
  }
  .hb__code code {
    display: block;
    white-space: pre;
  }
  .ln {
    display: inline-block;
    width: 2.4rem;
    padding-right: 1rem;
    text-align: right;
    color: var(--tn-fg-gutter, #3b4261);
    user-select: none;
  }
  /* current-line + sign-column cues, echoing the shipped highlights */
  .cur { color: var(--tn-orange); font-weight: 700; }
  .sg { box-shadow: inset 2px 0 0 var(--tn-red); }

  .c-cm { color: var(--tn-comment); font-style: italic; }
  .c-kw { color: var(--tn-magenta); }
  .c-fn { color: var(--tn-blue); }
  .c-fg { color: var(--tn-fg); }
  .c-str { color: var(--tn-green); }
  .c-cn { color: var(--tn-orange); }
  .c-ty { color: var(--tn-teal); }
  .c-nm { color: var(--tn-orange); }

  /* statusline — rounded NvChad blocks via border-radius (no Nerd Font needed) */
  .hb__stl {
    display: flex;
    align-items: stretch;
    gap: 0.3rem;
    padding: 0.35rem 0.5rem;
    background: var(--tn-bg-dark);
    border-top: 1px solid var(--border);
    font-size: 0.72rem;
  }
  .stl-blk {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.15rem 0.7rem;
    border-radius: 999px;
    color: var(--tn-fg);
    background: var(--tn-surface-2);
    white-space: nowrap;
  }
  .stl-ico { width: 0.85rem; height: 0.85rem; }
  .stl-mode {
    color: #10131f;
    font-weight: 700;
    background: var(--tn-blue);
  }
  .stl-git { color: var(--tn-green); }
  .stl-file { background: transparent; color: var(--text-dim); }
  .stl-fill { flex: 1; }
  .stl-diag { gap: 0.55rem; background: transparent; }
  .d-err { color: var(--tn-red); }
  .d-warn { color: var(--tn-yellow); }
  .stl-lsp { color: var(--tn-cyan); }
  .stl-cwd { color: var(--tn-purple); }
  .stl-loc {
    color: #10131f;
    font-weight: 700;
    background: var(--tn-blue);
  }
  @media (max-width: 640px) {
    .stl-lsp, .stl-cwd { display: none; }
  }
</style>
