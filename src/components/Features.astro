---
/*
 * Features.astro — the "why it's built this way" grid, in NvChad's content format.
 *
 * NvChad's most-copied website element is its feature grid: a circular icon badge
 * over a bold title and one terse line, laid out as an even showcase. This adapts
 * that format — replacing the old ad-hoc unicode glyphs (◆ ⧉ ⚡ …) with clean inline
 * Feather-style SVG icons in accent-tinted round badges. Icons are inlined (no icon
 * font, no dependency, CSP-safe) and stroke `currentColor`, so each takes the accent
 * colour from its `tone-*` class. Copy is unchanged — it's accurate to the system.
 */

// Feather (MIT) 24×24 stroke icons, inlined as raw <path> markup keyed per feature.
const icons = {
  copy: '<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>',
  package:
    '<line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>',
  terminal: '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>',
  layers:
    '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  compass:
    '<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>',
};

const features = [
  {
    icon: 'copy',
    accent: 'purple',
    title: 'Authored once, everywhere',
    body: 'Core lives in one repo and is vendored into every OS repo via git subtree. No N-way reconciliation, no drift — edit once, sync out.',
  },
  {
    icon: 'package',
    accent: 'blue',
    title: 'Clone-and-go',
    body: 'Subtree vendors the actual files, so a fresh clone just works. No submodule init, no flags. Perfect for public portfolio repos.',
  },
  {
    icon: 'terminal',
    accent: 'cyan',
    title: 'Same shell, every OS',
    body: 'The zsh module chain loads in one canonical order on macOS, Linux, and WSL — PowerShell mirrors it. Muscle memory transfers everywhere.',
  },
  {
    icon: 'shield',
    accent: 'green',
    title: 'Audited & benchmarked',
    body: 'A manifest-driven audit gate, hermetic behavioral tests, pinned plugin SHAs, and a startup-perf budget keep every sync honest.',
  },
  {
    icon: 'layers',
    accent: 'orange',
    title: 'Three clean layers',
    body: 'Core (identical everywhere), OS-native (changes with the OS), and Role (offensive scaffolding for Kali, defensive tooling for Defense). Every file has exactly one home.',
  },
  {
    icon: 'compass',
    accent: 'red',
    title: 'Discoverable by design',
    body: 'core-help cheat sheets, core-doctor health checks, did-you-mean command handling, and first-party completions for every verb.',
  },
];
---

<section class="section">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">Why it’s built this way</span>
      <h2>A system, not a pile of config</h2>
      <p class="lead">
        Ten repositories, one philosophy: if it changes with the operating system it
        isn’t Core; if it changes with you as an operator it isn’t Core. Everything left
        over is Core — and it lives in exactly one place.
      </p>
    </div>

    <div class="nv-features">
      {
        features.map((f) => (
          <article class="nv-feature">
            <span class:list={['nv-feature__badge', `tone-${f.accent}`]}>
              <svg
                class="nv-feature__icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={icons[f.icon as keyof typeof icons]}
              />
            </span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .nv-features {
    display: grid;
    gap: var(--gap);
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .nv-features {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 900px) {
    .nv-features {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* NvChad's feature card: icon badge centered over a bold title + one terse line */
  .nv-feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.4rem;
    padding: 2rem 1.5rem;
    background: linear-gradient(180deg, var(--tn-surface), var(--tn-bg-dark));
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .nv-feature:hover {
    transform: translateY(-4px);
    border-color: var(--tn-border-bright);
    box-shadow: var(--shadow);
  }

  /* the circular badge — soft shadow + a faint accent halo, NvChad's signature */
  .nv-feature__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.6rem;
    height: 3.6rem;
    margin-bottom: 0.8rem;
    border-radius: 999px;
    /* NO `color` here on purpose: the per-card `tone-*` class (global.css) owns it, and
       Astro's scoping would give a `.nv-feature__badge { color }` rule higher specificity
       than `.tone-purple`, pinning every badge to one accent. Everything below keys off
       `currentColor`, so the icon, halo, and border all inherit the tone-* colour. */
    background:
      radial-gradient(120% 120% at 50% 0%, color-mix(in srgb, currentColor 16%, transparent), transparent 70%),
      var(--tn-bg-dark);
    border: 1px solid color-mix(in srgb, currentColor 35%, var(--border));
    box-shadow:
      0 6px 18px -8px rgba(0, 0, 0, 0.7),
      inset 0 0 0 1px rgba(255, 255, 255, 0.03);
  }
  .nv-feature__icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  .nv-feature h3 {
    font-size: 1.1rem;
    margin: 0;
  }
  .nv-feature p {
    font-size: 0.92rem;
    color: var(--text-dim);
    margin: 0;
    max-width: 34ch;
  }
</style>
